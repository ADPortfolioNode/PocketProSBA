# Development Dockerfile for PocketPro:SBA
FROM python:3.11-slim

# Set the working directory in the container
WORKDIR /app

# Minimal pip startup settings for faster dependency installation
ENV PYTHONUNBUFFERED=1
ENV PIP_DISABLE_PIP_VERSION_CHECK=1
ENV PIP_DEFAULT_TIMEOUT=100

# Build tools required for native extensions (e.g. hnswlib from chromadb)
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    gcc \
    g++ \
    python3-dev \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements first for better caching
COPY backend/requirements.txt .

# Upgrade packaging tools and install dependencies in small batches.
# Reasons for this shape on low-RAM hosts (~8GB):
# - modern pip resolver backtracks heavily on chromadb/opentelemetry and OOMs
# - a single "Installing collected packages" of 100+ wheels also OOMs Docker Desktop
# - legacy-resolver + batched RUN layers keeps peak memory much lower
ENV PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DEFAULT_TIMEOUT=100

RUN python -m pip install --upgrade "pip<25" setuptools wheel

# Core web stack
RUN pip install --use-deprecated=legacy-resolver \
    flask==3.0.0 flask-cors==4.0.0 flask-socketio==5.3.6 \
    flask-sqlalchemy==3.1.1 gunicorn==21.2.0 \
    python-dotenv==1.0.0 requests==2.31.0 \
    pydantic==1.10.9 "urllib3>=1.26.0,<3.0.0" werkzeug==3.0.1 pytest==7.4.3

# Docs + numeric
RUN pip install --use-deprecated=legacy-resolver \
    numpy==1.26.2 pypdf2==3.0.1 python-docx==1.1.0 markdown==3.5.1

# LLM stack (without chromadb). Keep google-generativeai==0.4.1 with
# google-ai-generativelanguage==0.4.0 — newer generativeai 0.8.x expects a
# newer generativelanguage and fails with FileServiceClient AttributeError.
RUN pip install --use-deprecated=legacy-resolver \
    "onnxruntime>=1.18.0,<2.0" \
    google-generativeai==0.4.1 google-ai-generativelanguage==0.4.0 \
    langchain==0.1.14 langchain-community==0.0.38 langchain-google-genai==0.0.11

# Heaviest last: chromadb pulls many deps; isolate install peak.
# Stay on 0.4.24 — 0.5.x pulls FastAPI/pydantic v2 and breaks google-generativeai 0.4.1.
RUN pip install --use-deprecated=legacy-resolver chromadb==0.4.24

# Copy the entire project
COPY . .

# Set Python path to include the backend directory
ENV PYTHONPATH=/app/backend:/app/src

# Expose port
EXPOSE 5000

# Run the development server
CMD ["python", "run.py"]
